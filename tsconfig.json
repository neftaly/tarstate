{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noUncheckedSideEffectImports": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@tarstate/core": ["./packages/core/src/root.ts"],
      "@tarstate/core/artifacts": ["./packages/core/src/artifacts/index.ts"],
      "@tarstate/core/artifacts/constraint-set": ["./packages/core/src/artifacts/constraint-set/index.ts"],
      "@tarstate/core/artifacts/query": ["./packages/core/src/artifacts/query/index.ts"],
      "@tarstate/core/artifacts/schema-lens": ["./packages/core/src/artifacts/schema-lens/index.ts"],
      "@tarstate/core/artifacts/storage-mapping": ["./packages/core/src/artifacts/storage-mapping/index.ts"],
      "@tarstate/core/artifacts/transaction": ["./packages/core/src/artifacts/transaction/index.ts"],
      "@tarstate/core/attachment": ["./packages/core/src/attachment/index.ts"],
      "@tarstate/core/attachment/declaration": ["./packages/core/src/attachment/declaration/index.ts"],
      "@tarstate/core/attachment/adapter": ["./packages/core/src/attachment/adapter/index.ts"],
      "@tarstate/core/attachment/mapped-adapter": ["./packages/core/src/attachment/mapped-adapter/index.ts"],
      "@tarstate/core/attachment/text-intent-adapter": ["./packages/core/src/attachment/text-intent-adapter/index.ts"],
      "@tarstate/core/capabilities": ["./packages/core/src/capabilities/index.ts"],
      "@tarstate/core/database": ["./packages/core/src/database/index.ts"],
      "@tarstate/core/database/adapter": ["./packages/core/src/database/adapter/index.ts"],
      "@tarstate/core/database/external-store": ["./packages/core/src/database/external-store/index.ts"],
      "@tarstate/core/database/incremental": ["./packages/core/src/database/incremental/index.ts"],
      "@tarstate/core/database/observer": ["./packages/core/src/database/observer/index.ts"],
      "@tarstate/core/database/session": ["./packages/core/src/database/session/index.ts"],
      "@tarstate/core/query": ["./packages/core/src/query/index.ts"],
      "@tarstate/core/query/authoring": ["./packages/core/src/query/authoring/index.ts"],
      "@tarstate/core/query/evaluate": ["./packages/core/src/query/evaluate/index.ts"],
      "@tarstate/core/query/incremental": ["./packages/core/src/query/incremental/index.ts"],
      "@tarstate/core/query/model": ["./packages/core/src/query/model/index.ts"],
      "@tarstate/core/query/prepare": ["./packages/core/src/query/prepare/index.ts"],
      "@tarstate/core/schema": ["./packages/core/src/schema/index.ts"],
      "@tarstate/core/source": ["./packages/core/src/source/index.ts"],
      "@tarstate/core/transactions": ["./packages/core/src/transactions/index.ts"],
      "@tarstate/core/transactions/authoring": ["./packages/core/src/transactions/authoring/index.ts"],
      "@tarstate/core/values": ["./packages/core/src/values/index.ts"],
      "@tarstate/automerge/values": ["./packages/automerge/src/values/index.ts"],
      "@tarstate/automerge": ["./packages/automerge/src/index.ts"],
      "@tarstate/zustand": ["./packages/zustand/src/index.ts"],
      "@tarstate/react": ["./packages/react/src/index.ts"],
      "@tarstate/schema-tools": ["./packages/schema-tools/src/index.ts"],
      "@tarstate/schema-tools/artifact-bundle": ["./packages/schema-tools/src/artifact-bundle/index.ts"]
    },
    "moduleDetection": "force",
    "isolatedModules": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "examples",
    "packages/*/src",
    "packages/*/tests",
    "vite.config.ts"
  ]
}
