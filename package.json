{
  "name": "tarstate",
  "private": true,
  "version": "0.0.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.12.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "lint": "oxlint . --deny-warnings --type-aware",
    "test": "vitest run tests/*.test.ts --passWithNoTests && pnpm --filter './packages/*' --if-present test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
