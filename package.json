{
  "name": "tarstate",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.12.0"
  },
  "scripts": {
    "bench": "pnpm --filter './packages/*' --if-present bench",
    "bench:legacy": "node scripts/legacy-benchmark.mjs",
    "build": "pnpm --filter './packages/*' -r build",
    "check": "pnpm lint && pnpm typecheck && pnpm build && pnpm test",
    "dev": "pnpm -r --filter './apps/*' --parallel dev",
    "lint": "oxlint . --deny-warnings --type-aware",
    "relic:oracle": "TARSTATE_RELIC_ORACLE=1 pnpm --filter @tarstate/core exec vitest run --config ../../vite.config.ts tests/relic-oracle.test.ts",
    "test": "pnpm --filter './packages/*' test",
    "test:fuzz": "pnpm --filter './packages/*' --if-present test:fuzz",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
