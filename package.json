{
  "name": "@tarstate/monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm --filter ./packages/* --if-present build",
    "test": "pnpm --filter ./packages/* --if-present test && pnpm --filter ./apps/* --if-present test",
    "typecheck": "pnpm --filter ./packages/* --if-present typecheck && pnpm --filter ./apps/* --if-present typecheck"
  }
}
