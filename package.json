{
  "name": "tarstate",
  "private": true,
  "version": "0.3.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.12.0"
  },
  "scripts": {
    "bench": "pnpm --filter @tarstate/core build && pnpm --filter './packages/*' --if-present bench",
    "bench:query": "pnpm --filter @tarstate/core build && node --expose-gc scripts/query-performance.mjs",
    "bench:observer": "pnpm --filter @tarstate/core build && node --expose-gc scripts/observer-performance.mjs",
    "bench:legacy": "node scripts/legacy-benchmark.mjs",
    "build": "pnpm --filter './packages/*' -r build",
    "check": "pnpm lint && pnpm typecheck && pnpm typecheck:budget && pnpm build && pnpm test",
    "check:perf": "pnpm bench && pnpm bench:query && pnpm bench:observer",
    "check:release": "pnpm check && pnpm check:perf && tsc -p tsconfig.release.json && node scripts/verify-release.mjs",
    "lint": "oxlint . --deny-warnings --type-aware",
    "test": "pnpm --filter './packages/*' test",
    "test:fuzz": "pnpm --filter './packages/*' --if-present test:fuzz",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:budget": "pnpm --filter @tarstate/core typecheck:budget"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
