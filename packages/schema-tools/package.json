{
  "name": "@tarstate/schema-tools",
  "version": "0.7.0",
  "private": true,
  "description": "Deterministic schema and agent artifacts for Tarstate",
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/neftaly/tarstate.git", "directory": "packages/schema-tools" },
  "type": "module",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./artifact-bundle": {
      "types": "./dist/artifact-bundle/index.d.ts",
      "import": "./dist/artifact-bundle/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": { "node": ">=24.12.0" },
  "scripts": {
    "build": "vite build --config ../../vite.config.ts --logLevel warn && tsc -p tsconfig.build.json",
    "test": "vitest run --config ../../vite.config.ts --exclude 'tests/*.fuzz.spec.ts'",
    "typecheck": "tsc -p ../../tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tarstate/core": "workspace:^"
  }
}
