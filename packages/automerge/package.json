{
  "name": "@tarstate/automerge",
  "version": "0.4.3",
  "private": true,
  "description": "Automerge source and storage bindings for Tarstate",
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/neftaly/tarstate.git", "directory": "packages/automerge" },
  "type": "module",
  "files": ["dist", "!dist/internal-benchmark.*"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./values": {
      "types": "./dist/values/index.d.ts",
      "import": "./dist/values/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": { "node": ">=24.12.0" },
  "scripts": {
    "build": "vite build --config ../../vite.config.ts --logLevel warn && tsc -p tsconfig.build.json",
    "test": "vitest run --config ../../vite.config.ts tests/*.test.ts",
    "test:fuzz": "vitest run --config ../../vite.config.ts tests/*.fuzz.spec.ts",
    "typecheck": "tsc -p ../../tsconfig.json --noEmit"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.6",
    "@tarstate/core": "workspace:^"
  },
  "devDependencies": {
    "@automerge/automerge-repo": "2.5.6",
    "fast-check": "^4.9.0",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
