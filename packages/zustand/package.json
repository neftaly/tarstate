{
  "name": "@tarstate/zustand",
  "version": "0.6.9",
  "private": true,
  "description": "Zustand adapter for Tarstate's atomic external-store protocol",
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/neftaly/tarstate.git", "directory": "packages/zustand" },
  "type": "module",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": { "node": ">=24.12.0" },
  "scripts": {
    "build": "vite build --config ../../vite.config.ts --logLevel warn && tsc -p tsconfig.build.json",
    "test": "vitest run --config ../../vite.config.ts --exclude 'tests/*.fuzz.spec.ts'",
    "typecheck": "tsc -p ../../tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tarstate/core": "workspace:^"
  },
  "peerDependencies": {
    "zustand": ">=5.0.0 <6"
  },
  "devDependencies": {
    "@tanstack/store": "0.11.0",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "zustand": "5.0.14"
  }
}
