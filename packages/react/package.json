{
  "name": "@tarstate/react",
  "version": "0.6.2",
  "private": true,
  "description": "React observer and commit bindings for Tarstate",
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/neftaly/tarstate.git", "directory": "packages/react" },
  "type": "module",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": { "node": ">=24.12.0" },
  "scripts": {
    "build": "vite build --config ../../vite.config.ts --logLevel warn && tsc -p tsconfig.build.json",
    "test": "vitest run --config ../../vite.config.ts --exclude 'tests/*.fuzz.spec.ts'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tarstate/core": "workspace:^"
  },
  "peerDependencies": {
    "react": ">=18.3.0 <20"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-test-renderer": "19.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-test-renderer": "19.2.7",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
