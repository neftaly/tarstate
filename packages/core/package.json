{
  "name": "@tarstate/core",
  "version": "0.2.1",
  "description": "Portable relational semantics and source protocols for Tarstate",
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/neftaly/tarstate.git", "directory": "packages/core" },
  "type": "module",
  "files": ["dist", "!dist/golden-workloads.*"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=24.12.0" },
  "scripts": {
    "bench": "node ../../scripts/v1-coarse-benchmark.mjs",
    "build": "vite build --config ../../vite.config.ts --logLevel warn && tsc -p tsconfig.build.json",
    "test": "vitest run --config ../../vite.config.ts tests/*.test.ts",
    "test:fuzz": "vitest run --config ../../vite.config.ts tests/fuzz-properties.test.ts",
    "typecheck:budget": "tsc -p type-fixtures/tsconfig.json --extendedDiagnostics --pretty false | node scripts/check-type-budget.mjs",
    "typecheck": "tsc -p ../../tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
